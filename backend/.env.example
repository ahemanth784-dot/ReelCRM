# Environment Variables for ReelCRM Backend
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL - Get this from Neon.tech or Supabase
DATABASE_URL=postgresql://user:password@host:5432/reelcrm

# JWT Secret - Use a long random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional secure first-admin initialization (only used when no admin exists)
FIRST_ADMIN_NAME=Aluvala Hemanth
FIRST_ADMIN_EMAIL=ahemanth784@gmail.com
FIRST_ADMIN_PASSWORD=ChangeMe@12345
